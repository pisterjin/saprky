# Ollama 설정
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b

# PostgreSQL 연결
DATABASE_URL=postgresql://sparky:sparky1234@localhost:5433/sparky

# RAG 설정
EMBEDDING_MODEL=snunlp/KR-SBERT-V40K-klueNLI-augSTS
SIMILARITY_THRESHOLD=1.5
FAISS_INDEX_PATH=./data/faiss_index

# CORS (프론트 주소, 콤마로 여러 개 가능)
ALLOWED_ORIGINS=http://localhost:3000

# 온통청년 API (공공데이터포털에서 발급)
# 발급: https://www.data.go.kr → "온통청년" 검색 → 활용신청
ONTONG_API_KEY=여기에_발급받은_키_입력

# 정부24 오픈 API 키(추후 추가 시)
# 발급: https://www.data.go.kr/data/15113968/openapi.do → 활용신청
GOV_API_KEY=your_key

# 모델 선택 (gpt 또는 ollama)
# .env 파일은 # 만 주석으로 인식합니다.
# GPT 쓸 때: USE_MODEL=gpt
# Ollama 쓸 때: USE_MODEL=ollama
USE_MODEL=ollama
GPT_API_KEY=sk-your_key_here


